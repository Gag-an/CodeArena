generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  playerId  String   @unique
  email     String   @unique
  password  String
  username  String   @unique
  avatar    String?
  
  // New Profile Fields
  college         String?
  leetcode_link   String?
  hackerearth_link String?

  // Gamification Stats
  xp        Int      @default(0)
  level     Int      @default(1)
  rank      String   @default("Bronze")
  coins     Int      @default(0)
  wins      Int      @default(0)
  losses    Int      @default(0)
  
  activities  HeatmapActivity[]
  submissions Submission[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HeatmapActivity {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      String   // ISO Date string like '2023-08-01'
  level     Int      // 0 to 4
  
  @@unique([userId, date])
}

model Submission {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  problemName String
  difficulty  String   @default("Easy")
  createdAt   DateTime @default(now())
}